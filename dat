local Loops = {}

local function StopLoop(loop)
    if loop then loop:Disconnect() end
end

local function GetCharacter()
    Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Humanoid = Character:FindFirstChildOfClass("Humanoid")
    RootPart = Character:FindFirstChild("HumanoidRootPart")
    return Humanoid and Humanoid.Health > 0
end

local function GetAimPart(plr)
    if not plr or not plr.Character then return nil end
    return Config.AimPart == "Head" and plr.Character:FindFirstChild("Head")
        or plr.Character:FindFirstChild("UpperTorso")
        or plr.Character:FindFirstChild("HumanoidRootPart")
end

local function IsVisible(targetPos)
    if not GetCharacter() or not RootPart then return false end
    local eyePos = Camera.CFrame.Position
    local ray = Ray.new(eyePos, (targetPos - eyePos).Unit * Config.AimRange)
    local hit = Workspace:FindPartOnRayWithIgnoreList(ray, {Character, Camera})
    return not hit or (hit.Position - targetPos).Magnitude < 2
end

local function GetClosestPlayer()
    local closest, bestDist = nil, math.huge
    local camPos = Camera.CFrame.Position
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local part = GetAimPart(plr)
        local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
        if not part or not hum or hum.Health <= 0 then continue end

        local dist3D = (part.Position - camPos).Magnitude
        if dist3D > Config.AimRange then continue end

        if Config.AimOnlyVisible and not IsVisible(part.Position) then continue end

        local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen or sp.Z < 1 then continue end

        local dist2D = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        local fovRadius = math.tan(math.rad(Config.AimFOV / 2)) * (Camera.ViewportSize.Y / 2)
        if dist2D < bestDist and dist2D <= fovRadius then
            bestDist = dist2D
            closest = part
        end
    end
    return closest
end

local function StopSpectate()
    if Config.Spectating then
        Camera.CameraType = OriginalCameraType
        Camera.CameraSubject = OriginalCameraSubject
        Config.Spectating = false
        Config.CurrentSpectate = nil
        StarterGui:SetCore("SendNotification", {Title = "Legit Dat", Text = "Stopped spectating", Duration = 2})
    end
end

-- ✅ Reset player properly
local function ReturnPlayer(plr)
    if not plr or not plr.Character then return end
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    -- Remove all control objects
    for _, obj in ipairs(root:GetChildren()) do
        if obj:IsA("BodyPosition") or obj:IsA("BodyGyro") or obj:IsA("BodyVelocity")
        or obj:IsA("AlignPosition") or obj:IsA("AlignOrientation") or obj.Name == "BringValue" then
            obj:Destroy()
        end
    end

    -- Restore movement
    hum.PlatformStand = false
    hum.WalkSpeed = 16
    hum.JumpPower = 50
    hum.AutoRotate = true
    hum:ChangeState(Enum.HumanoidStateType.Running)
end

local function ReturnAllBrought()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ReturnPlayer(plr)
        end
    end
end

-- ✅ NEW BRING METHOD: Direct CFrame manipulation (works in EVERY game)
local function BringPlayer(plr, index)
    if not plr or not plr.Character then return end
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then return end

    -- Freeze movement input
    hum.PlatformStand = true
    hum.WalkSpeed = 0
    hum.JumpPower = 0
    hum.AutoRotate = false

    -- Calculate position
    local offset = -RootPart.CFrame.RightVector * Config.BringSpacing
    local targetPos = RootPart.Position + offset * (index - 1) + Vector3.new(0, Config.BringHeight, 0)
    local targetCFrame = CFrame.new(targetPos, RootPart.Position)

    -- Direct set CFrame — no physics objects = no blocks
    root.CFrame = targetCFrame
end

