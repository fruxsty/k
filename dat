            row.Size = UDim2.new(0.96, 0, 0, 32)
            row.BackgroundColor3 = table.find(Config.SelectedTargets, plr) and Config.Colors.Green or Color3.fromRGB(235, 225, 205)
            row.BorderSizePixel = 0
            row.Parent = listFrame
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(0.55, 0, 1, 0)
            nameLabel.Position = UDim2.new(0, 8, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Font = Enum.Font.GothamSemibold
            nameLabel.TextSize = 13
            nameLabel.TextColor3 = Config.Colors.Text
            nameLabel.Text = plr.DisplayName
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = row

            local selectBtn = Instance.new("TextButton")
            selectBtn.Size = UDim2.new(0.2, 0, 0.8, 0)
            selectBtn.Position = UDim2.new(0.58, 0, 0.1, 0)
            selectBtn.BackgroundColor3 = Color3.fromRGB(220, 205, 180)
            selectBtn.Text = table.find(Config.SelectedTargets, plr) and "Selected" or "Select"
            selectBtn.Font = Enum.Font.GothamBold
            selectBtn.TextSize = 11
            selectBtn.TextColor3 = Config.Colors.Text
            selectBtn.BorderSizePixel = 0
            selectBtn.Parent = row
            Instance.new("UICorner", selectBtn).CornerRadius = UDim.new(0, 4)

            local spectateBtn = Instance.new("TextButton")
            spectateBtn.Size = UDim2.new(0.2, 0, 0.8, 0)
            spectateBtn.Position = UDim2.new(0.8, 0, 0.1, 0)
            spectateBtn.BackgroundColor3 = Color3.fromRGB(220, 205, 180)
            spectateBtn.Text = "Spectate"
            spectateBtn.Font = Enum.Font.GothamBold
            spectateBtn.TextSize = 11
            spectateBtn.TextColor3 = Config.Colors.Text
            spectateBtn.BorderSizePixel = 0
            spectateBtn.Parent = row
            Instance.new("UICorner", spectateBtn).CornerRadius = UDim.new(0, 4)

            selectBtn.MouseButton1Click:Connect(function()
                local idx = table.find(Config.SelectedTargets, plr)
                if idx then
                    table.remove(Config.SelectedTargets, idx)
                    row.BackgroundColor3 = Color3.fromRGB(235, 225, 205)
                    selectBtn.Text = "Select"
                else
                    table.insert(Config.SelectedTargets, plr)
                    row.BackgroundColor3 = Config.Colors.Green
                    selectBtn.Text = "Selected"
                end
            end)

            spectateBtn.MouseButton1Click:Connect(function()
                if Config.Spectating and Config.CurrentSpectate == plr then
                    StopSpectate()
                    spectateBtn.Text = "Spectate"
                    spectateBtn.BackgroundColor3 = Color3.fromRGB(220, 205, 180)
                    return
                end
                if not plr.Character or not plr.Character:FindFirstChild("Humanoid") then
                    StarterGui:SetCore("SendNotification", {Title = "Legit Dat", Text = "Player not loaded", Duration = 2})
                    return
                end
                StopSpectate()
                OriginalCameraType = Camera.CameraType
                OriginalCameraSubject = Camera.CameraSubject
                Camera.CameraType = Enum.CameraType.Custom
                Camera.CameraSubject = plr.Character:FindFirstChild("Humanoid")
                Config.Spectating = true
                Config.CurrentSpectate = plr
                spectateBtn.Text = "Stop"
                spectateBtn.BackgroundColor3 = Config.Colors.Red
                StarterGui:SetCore("SendNotification", {Title = "Legit Dat", Text = "Spectating: " .. plr.DisplayName, Duration = 2})
            end)
        end
    end
    RefreshPlayers()
    Players.PlayerAdded:Connect(RefreshPlayers)
    Players.PlayerRemoving:Connect(function(plr)
        local idx = table.find(Config.SelectedTargets, plr)
        if idx then table.remove(Config.SelectedTargets, idx) end
        RefreshPlayers()
    end)
end

local function LoadSettingsTab()
    ClearContent()
    AddSection("MENU SETTINGS")
    AddKeybind("Menu Toggle Key", Config.MenuToggleKey, function(v) Config.MenuToggleKey = v end)
    AddToggle("Draggable Menu", true, function(v) Main.Draggable = v end)
    AddSlider("Menu Opacity", 1, 0.2, 1, function(v)
        Main.BackgroundTransparency = 1 - v
        TitleBar.BackgroundTransparency = 1 - v
    end)

    AddSection("KEYBINDS")
    AddKeybind("Flight Key", Config.FlightKey, function(v) Config.FlightKey = v end)
    AddKeybind("NoClip Key", Config.NoClipKey, function(v) Config.NoClipKey = v end)
    AddKeybind("Follow Key", Config.FollowKey, function(v) Config.FollowKey = v end)
    AddKeybind("Bring Selected Key", Config.BringTargetKey, function(v) Config.BringTargetKey = v end)
    AddKeybind("Bring All Key", Config.BringAllKey, function(v) Config.BringAllKey = v end)
end

-- ======================================
-- TAB SWITCH & INPUT
-- ======================================
local function SwitchTab(tabName)
    Config.CurrentTab = tabName
    Tab_Main.BackgroundColor3 = tabName == "Main" and Config.Colors.TabActive or Config.Colors.TabInactive
    Tab_Players.BackgroundColor3 = tabName == "Players" and Config.Colors.TabActive or Config.Colors.TabInactive
    Tab_Settings.BackgroundColor3 = tabName == "Settings" and Config.Colors.TabActive or Config.Colors.TabInactive

    if tabName == "Main" then LoadMainTab()
    elseif tabName == "Players" then LoadPlayersTab()
    elseif tabName == "Settings" then LoadSettingsTab() end
end

Tab_Main.MouseButton1Click:Connect(function() SwitchTab("Main") end)
Tab_Players.MouseButton1Click:Connect(function() SwitchTab("Players") end)
Tab_Settings.MouseButton1Click:Connect(function() SwitchTab("Settings") end)

MinBtn.MouseButton1Click:Connect(function()
    local isMin = Main.Size.Y.Offset == 42
    if isMin then
        Main.Size = UDim2.new(0, Config.WindowWidth, 0, Config.WindowHeight)
        TabFrame.Visible = true
        Content.Visible = true
        MinBtn.Text = "−"
    else
        Main.Size = UDim2.new(0, Config.WindowWidth, 0, 42)
        TabFrame.Visible = false
        Content.Visible = false
        MinBtn.Text = "+"
    end
end)

UserInputService.InputBegan:Connect(function(i, processed)
    if processed then return end
    if i.KeyCode == Config.MenuToggleKey then
        Config.MenuVisible = not Config.MenuVisible
        Main.Visible = Config.MenuVisible
        StarterGui:SetCore("SendNotification", {Title = "Menu", Text = Config.MenuVisible and "Opened" or "Closed", Duration = 1})
        return
    end
    if i.KeyCode == Enum.KeyCode.Escape and Config.Spectating then
        StopSpectate()
    end
end)

UserInputService.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton2 then
        if Config.AimLockEnabled then
            Config.AimLockHeld = true
            Loops.AimLock = RunService.RenderStepped:Connect(function()
                local target = GetClosestPlayer()
                if target then
                    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), Config.AimSmooth)
                end
            end)
        end
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton2 then
        Config.AimLockHeld = false
        StopLoop(Loops.AimLock)
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    StopSpectate()
    ReturnAllBrought()
    for _, loop in pairs(Loops) do StopLoop(loop) end
    MainGui:Destroy()
end)

-- Load default tab
SwitchTab("Main")
