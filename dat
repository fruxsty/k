local function LoadMainTab()
    ClearContent()

    AddSection("MOVEMENT")
    AddToggle("Flight", false, function(v)
        Config.FlightActive = v
        if v then
            if not GetCharacter() then return end
            Humanoid.PlatformStand = true
            local bv = Instance.new("BodyVelocity", RootPart)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            local bg = Instance.new("BodyGyro", RootPart)
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bg.P = 9000
            Loops.Flight = RunService.RenderStepped:Connect(function()
                if not Config.FlightActive or not GetCharacter() then return end
                local move = Vector3.new()
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += Camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= Camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= Camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += Camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0, 1, 0) end
                local speed = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and Config.FlightSpeed * Config.FlightBoost or Config.FlightSpeed
                bv.Velocity = move.Magnitude > 0 and move.Unit * speed or Vector3.zero
                bg.CFrame = CFrame.new(RootPart.Position, RootPart.Position + Camera.CFrame.LookVector)
            end)
        else
            StopLoop(Loops.Flight)
            if GetCharacter() then
                Humanoid.PlatformStand = false
                RootPart:FindFirstChildOfClass("BodyVelocity"):Destroy()
                RootPart:FindFirstChildOfClass("BodyGyro"):Destroy()
            end
        end
    end)
    AddSlider("Flight Speed", Config.FlightSpeed, 20, 500, function(v) Config.FlightSpeed = v end)
    AddSlider("Flight Boost", Config.FlightBoost, 1, 10, function(v) Config.FlightBoost = v end)

    AddToggle("NoClip", false, function(v)
        Config.NoClipActive = v
        if v then
            Loops.NoClip = RunService.Heartbeat:Connect(function()
                if GetCharacter() then
                    for _, part in ipairs(Character:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
            end)
        else
            StopLoop(Loops.NoClip)
            if GetCharacter() then
                for _, part in ipairs(Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = true end
                end
            end
        end
    end)

    AddSection("AIM ASSIST")
    AddToggle("Aim Lock", false, function(v)
        Config.AimLockEnabled = v
        if not v then
            Config.AimLockHeld = false
            StopLoop(Loops.AimLock)
        end
    end)
    AddToggle("Only Aim Visible Players", Config.AimOnlyVisible, function(v) Config.AimOnlyVisible = v end)
    AddSlider("FOV Range", Config.AimFOV, 20, 180, function(v) Config.AimFOV = v end)
    AddSlider("Smoothness", Config.AimSmooth, 0, 1, function(v) Config.AimSmooth = v end)
    AddSlider("Max Range", Config.AimRange, 100, 3000, function(v) Config.AimRange = v end)

    AddSection("PLAYER CONTROL")
    AddToggle("Follow Selected", false, function(v)
        Config.FollowActive = v
        if v then
            if #Config.SelectedTargets == 0 then
                StarterGui:SetCore("SendNotification", {Title = "Follow", Text = "Select players first!", Duration = 2})
                return
            end
            Loops.Follow = RunService.Heartbeat:Connect(function()
                if not GetCharacter() or #Config.SelectedTargets == 0 then return end
                local t = Config.SelectedTargets[1]
                if not t or not t.Character then return end
                local tr = t.Character:FindFirstChild("HumanoidRootPart")
                if not tr then return end
                RootPart.CFrame = CFrame.new(tr.Position + (RootPart.Position - tr.Position).Unit * Config.FollowDist + Vector3.new(0, 1.5, 0), tr.Position)
            end)
        else
            StopLoop(Loops.Follow)
        end
    end)

    AddSlider("Bring Spacing", Config.BringSpacing, 1, 15, function(v) Config.BringSpacing = v end)
    AddSlider("Bring Height", Config.BringHeight, 0, 50, function(v) Config.BringHeight = v end)

    -- ✅ Bring Selected — using direct CFrame method
    AddToggle("Bring Selected", false, function(v)
        Config.BringTargetActive = v
        if v then
            if #Config.SelectedTargets == 0 then
                StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Select players in Players tab first!", Duration = 3})
                return
            end
            if not GetCharacter() then
                StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Load your character first!", Duration = 2})
                return
            end
            ReturnAllBrought()
            Loops.BringTarget = RunService.Heartbeat:Connect(function()
                if not GetCharacter() then return end
                for i, plr in ipairs(Config.SelectedTargets) do
                    BringPlayer(plr, i)
                end
            end)
            StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Bring Selected ON", Duration = 2})
        else
            StopLoop(Loops.BringTarget)
            ReturnAllBrought()
            StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Bring Selected OFF", Duration = 2})
        end
    end)

    -- ✅ Bring All — using direct CFrame method
    AddToggle("Bring All", false, function(v)
        Config.BringAllActive = v
        if v then
            if not GetCharacter() then
                StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Load your character first!", Duration = 2})
                return
            end
            ReturnAllBrought()
            Loops.BringAll = RunService.Heartbeat:Connect(function()
                if not GetCharacter() then return end
                local list = {}
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then table.insert(list, plr) end
                end
                for i, plr in ipairs(list) do
                    BringPlayer(plr, i)
                end
            end)
            StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Bring All ON", Duration = 2})
        else
            StopLoop(Loops.BringAll)
            ReturnAllBrought()
            StarterGui:SetCore("SendNotification", {Title = "Bring", Text = "Bring All OFF", Duration = 2})
        end
    end)
end

